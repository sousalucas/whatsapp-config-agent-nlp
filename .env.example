# LLM Provider
LLM_PROVIDER=anthropic          # anthropic | gemini | mock
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_API_KEY=                  # required when LLM_PROVIDER=gemini
GOOGLE_MODEL=gemini-2.0-flash

# WATI API
WATI_MODE=mock                   # mock | real
WATI_API_URL=https://live-mt-server.wati.io/YOUR_TENANT
WATI_API_TOKEN=your-bearer-token

# Agent
AGENT_LOCALE=                    # en | pt (auto-detected from user input if not set)
WEB_PORT=3000